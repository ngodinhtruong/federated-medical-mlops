# ===== identity =====
ROLE=server
DATA_SEED=1

# ===== data =====
# server chỉ dùng cluster_server.npz → không cần DATA_N
VAL_RATIO=0.0

# ===== flower server =====
FL_SERVER_ADDRESS=0.0.0.0:8080
FL_ROUNDS=5
FL_MIN_CLIENTS=2
FL_MIN_FIT_CLIENTS=2
FL_MIN_EVAL_CLIENTS=1

# ===== minio =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345
MINIO_BUCKET=fl-artifacts

# ===== logging =====
SERVER_LOG_LEVEL=INFO

# ===== airflow =====
AIRFLOW_PORT=8081
