# ===== identity =====
ROLE=client
CLIENT_ID=A
NUM_CLIENTS=2
DATA_SEED=1

# ===== data split control =====
CLIENT_RATIOS=0.5,0.5
VAL_RATIO=0.2
STREAM_BATCH = 500
# ===== status flags =====
CLIENT_HAS_DATA=true
CLIENT_CAN_TRAIN=true

# ===== minio =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345
MINIO_BUCKET=fl-artifacts

# ===== flower =====
FL_SERVER_ADDRESS=fl-server:8080

# ===== delay =====
CLIENT_DELAY_SEC=0
CLIENT_DELAY_JITTER_SEC=5

# ===== airflow =====
AIRFLOW_PORT=8082